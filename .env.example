# ===== 大模型 (LLM) 配置 =====
# 兼容 OpenAI API 格式的大模型服务，例如 OpenAI / DeepSeek / Moonshot / 通义千问 等
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ===== 微信公众号配置 =====
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# 文章默认作者署名
WECHAT_AUTHOR=AI趋势速递
# 默认封面图片本地路径或 URL（用于上传永久素材作为草稿封面）
WECHAT_DEFAULT_COVER=

# ===== 抓取数据源配置 =====
# 逗号分隔，可选：github_trending,hacker_news,crypto_news
# - github_trending: GitHub 每日趋势仓库，偏 AI 应用/工具
# - hacker_news: Hacker News 热门话题，偏科技/AI 综合资讯
# - crypto_news: CryptoCompare 快讯，偏 Crypto/Web3 应用资讯
SOURCES=github_trending,hacker_news,crypto_news
# 每个来源最多抓取的条目数
SOURCE_FETCH_LIMIT=5
# 最终生成文章合并的资讯条数
ARTICLE_ITEM_COUNT=6

# ===== 调度配置 =====
# cron 表达式，默认每天上午 10:30 执行一次
CRON_SCHEDULE=30 10 * * *
# 时区
TZ=Asia/Shanghai

# ===== 运行模式 =====
# dry_run=true 时只生成内容、不调用微信接口发布，便于本地调试
DRY_RUN=false
# 数据存储目录（用于记录已发布过的资讯，避免重复）
DATA_DIR=./data
